# =======================
# IntelliJ IDEA 配置文件
# =======================
# 忽略整个 .idea 文件夹（包含 workspace.xml, tasks.xml 等个人设置）
.idea/

# 忽略所有模块的 .iml 文件（如 web-ai-project03.iml, tlias-web-managment.iml）
*.iml

# 忽略由 IDEA 生成的杂项文件
*.iws
*.ipr
out/

# =======================
# Maven / Gradle 构建产物
# =======================
# 忽略编译后的 target 目录（这是最重要的，不要提交编译结果）
target/
**/target/

# 忽略 Maven 包装器脚本（如果你不需要团队同步特定版本的 mvnw）
mvnw
mvnw.cmd
.mvn/wrapper/maven-wrapper.jar

# =======================
# 操作系统临时文件
# =======================
.DS_Store       # macOS
Thumbs.db       # Windows